<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. STOP if this is a real file or directory (Images, JS/CSS, etc.)
  # This prevents LiteSpeed from trying to pass static assets to Node.js
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. SPA ROUTING: If the file doesn't exist, send it to index.html
  # We check the root first (flattened prod), then /dist/ (local dev fallback)
  RewriteCond %{DOCUMENT_ROOT}/index.html -f
  RewriteRule . /index.html [L]

  RewriteCond %{DOCUMENT_ROOT}/dist/index.html -f
  RewriteRule . /dist/index.html [L]
</IfModule>

# Handle Content-Type for modern Vite assets
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
</IfModule>



